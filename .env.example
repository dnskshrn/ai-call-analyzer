# PBX authentication token — must match what PBX sends in crm_token field
PBX_CRM_TOKEN=your_pbx_crm_token_here

# OpenAI API key for Whisper transcription and GPT-4o-mini summarisation
OPENAI_API_KEY=sk-...

# AmoCRM long-lived access token
AMO_LONG_TOKEN=your_amocrm_long_token_here

# AmoCRM subdomain (the part before .amocrm.ru)
AMO_SUBDOMAIN=deniskosharny

# Port for the Express server (Railway sets this automatically)
PORT=3000
